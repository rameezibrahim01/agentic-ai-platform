# Copy to .env (untracked — CLAUDE.md #4) and fill in. Never commit values.

# Required: bundled Postgres superuser password for this deployment.
POSTGRES_PASSWORD=

# Optional (ticket 026): enables the real Anthropic provider. Without it the
# worker runs the hermetic stub model — every drill still passes offline.
# The key goes ONLY into the provider's request header, never into logs,
# events, or traces (enforced by the secrets-scan drill).
ANTHROPIC_API_KEY=

# Optional (ticket 026): path INSIDE the worker container to a mounted
# models config (allowlist + pricing). A key alone never widens the model
# allowlist — without this file only stub-model is callable.
# Example file: see models.config.example.json
MODELS_CONFIG=

# Optional: policy environment for the whole profile (default prod).
PLATFORM_ENV=

# Optional (ticket 035): 64-hex AES-256 data key. Set = event payloads are
# encrypted at rest and only key-holders can read them; unset = plaintext.
# Losing/revoking the key makes existing logs verifiably unreadable.
PLATFORM_DATA_KEY=

# Optional (tickets 036-039): tenanted mode. Point at the mounted tenants
# file (/etc/platform/tenants.config.json) to run one isolated lane per
# tenant — own Postgres schema, own task queue, own data key. Empty =
# single-tenant boot, byte-identical to before tenancy.
TENANTS_CONFIG=

# Per-tenant 64-hex data keys (036): variable NAMES must match each tenant's
# dataKeyEnv in tenants.config.json. A named-but-empty key refuses boot.
ACME_DATA_KEY=
GLOBEX_DATA_KEY=

# Per-tenant provider keys (046): a models.<id>.config.json may name its own
# apiKeyEnv (e.g. ACME_ANTHROPIC_KEY=) — that lane then bills to that key.
# Named-but-empty refuses boot; absent falls back to ANTHROPIC_API_KEY.

# Optional (drill p4-3): tenant binding for the DEV fallback console account.
# Real deployments bind tenants via AUTH_ACCOUNTS_FILE or OIDC tenantMap.
AUTH_DEV_TENANT=

# Optional (ticket 051): approval notifications. Path INSIDE the worker
# container to a mounted notifications config naming webhookUrlEnv; the
# named env var holds the webhook URL (it usually embeds a token — treat it
# as a secret). Empty = no notifications.
NOTIFICATIONS_CONFIG=
APPROVALS_WEBHOOK_URL=

# Optional (ticket 040): SCIM provisioning. SCIM_TOKEN_ENV names the env var
# holding the bearer token the IdP presents (never the token itself here);
# the named var must then be set too. Requires OIDC_CONFIG (its role/tenant
# maps are the provisioning maps) and DATABASE_URL. Empty = SCIM off (404).
SCIM_TOKEN_ENV=
