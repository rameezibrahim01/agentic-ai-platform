# Copy to .env (untracked — CLAUDE.md #4) and fill in. Never commit values.

# Required: bundled Postgres superuser password for this deployment.
POSTGRES_PASSWORD=

# Optional (ticket 026): enables the real Anthropic provider. Without it the
# worker runs the hermetic stub model — every drill still passes offline.
# The key goes ONLY into the provider's request header, never into logs,
# events, or traces (enforced by the secrets-scan drill).
ANTHROPIC_API_KEY=

# Optional (ticket 026): path INSIDE the worker container to a mounted
# models config (allowlist + pricing). A key alone never widens the model
# allowlist — without this file only stub-model is callable.
# Example file: see models.config.example.json
MODELS_CONFIG=

# Optional: policy environment for the whole profile (default prod).
PLATFORM_ENV=
